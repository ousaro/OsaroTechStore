{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://osarotechstore.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://osarotechstore.onrender.com/uploads/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://osarotechstore.onrender.com;"
        }
      ]
    }
  ]
}
