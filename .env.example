# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose — Optional Overrides
# docker compose up works WITHOUT this file (dev defaults are baked in).
# Copy to .env and set these ONLY for production overrides.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB root password (default: dev-mongo-password-123)
# MONGO_ROOT_PASSWORD=your-strong-password

# JWT signing secret (default: dev-jwt-secret-change-in-production)
# TOKEN_SECRET=your-random-64-char-secret

# Stripe (default: disabled in backend, pk_test_key in frontend)
# STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
# REACT_APP_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx
