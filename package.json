{
  "name": "osarotechstore",
  "version": "2.0.0",
  "private": true,
  "description": "OsaroTechStore monorepo — development tooling",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "backend/**/*.{js,ts}": [
      "prettier --write"
    ],
    "frontend/src/**/*.{js,jsx}": [
      "prettier --write"
    ],
    "*.{yml,yaml,md,json}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
