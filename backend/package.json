{
  "name": "osaro-tech-store-backend",
  "version": "2.0.0",
  "description": "DDD + Modular Hexagonal Architecture",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "backend": "node src/server.js",
    "dev": "tsx watch src/server.js",
    "dev:js": "node --watch src/server.js",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .js",
    "format": "prettier --write \"**/*.{js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,yml,yaml}\"",
    "test": "NODE_OPTIONS='--import tsx/esm' node --test $(find tests/unit tests/integration -name '*.test.js' -print)",
    "test:unit": "NODE_OPTIONS='--import tsx/esm' node --test $(find tests/unit -name '*.test.js' -print)",
    "test:integration": "NODE_OPTIONS='--import tsx/esm' node --test $(find tests/integration -name '*.test.js' -print)",
    "test:flakiness": "for i in 1 2 3; do echo \"=== Run $i ===\"; NODE_OPTIONS='--import tsx/esm' npx --yes node --test $(find tests/unit tests/integration -name '*.test.js' -print) 2>&1 | tail -5; done",
    "coverage": "c8 npm test",
    "coverage:sonar": "c8 --reporter=lcov --report-dir=coverage npm test",
    "coverage:unit:html": "c8 --all=false --reporter=html --report-dir=tests/coverage/unit/html npm run test:unit",
    "coverage:integration:html": "c8 --all=false --reporter=html --report-dir=tests/coverage/integration/html npm run test:integration",
    "coverage:html": "c8 --reporter=html --report-dir=tests/coverage/global/html npm test",
    "migrate": "node migrations/migrate.js",
    "migrate:down": "node migrations/migrate.js down",
    "migrate:create": "node migrations/migrate.js create",
    "sonar": "npx @sonar/scan",
    "sonar:local": "set -a; . ./.env.sonar; set +a; npx @sonar/scan -Dsonar.host.url=$SONAR_HOST_URL -Dsonar.organization=$SONAR_ORGANIZATION"
  },
  "c8": {
    "all": true,
    "include": [
      "src/**/*.js"
    ],
    "check-coverage": true,
    "branches": 50,
    "functions": 50,
    "lines": 60,
    "statements": 60,
    "exclude": [
      "src/server.js",
      "tests/**",
      "coverage/**"
    ],
    "reporter": [
      "text",
      "html"
    ],
    "reports-dir": "tests/coverage/global/html"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-prom-bundle": "^8.0.0",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.2.0",
    "mongoose": "^8.3.4",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^10.3.1",
    "redis": "^5.12.1",
    "stripe": "^15.7.0",
    "validator": "^13.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "c8": "^11.0.0",
    "eslint": "^9.39.4",
    "mongodb-memory-server": "^11.1.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
