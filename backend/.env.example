# ─────────────────────────────────────────────────────────────────────────────
# osaroTechStore Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=5000

# ── Auth ──────────────────────────────────────────────────────────────────────
TOKEN_SECRET=your-very-long-random-secret-here
TOKEN_EXPIRES_IN=2d

# ── Logger ───────────────────────────────────────────────────────────────────
# Switch logger: set LOGGER_PROVIDER=console | pino | noop
LOGGER_PROVIDER=console

NO_COLOR=fasle
LOGGER_TIMESTAMP_FORMAT=YYYY-MM-DD HH:mm:ss.SSS
LOGGER_TIMESTAMP_ENABLED=true

# ── Database ──────────────────────────────────────────────────────────────────
# Switch by changing DATABASE_PROVIDER.
# Options: "mongo" | "postgres"
DATABASE_PROVIDER=mongo
MONGO_URI=mongodb://localhost:27017/osarotechstore
# POSTGRES_URL=postgresql://user:pass@localhost:5432/osarotechstore

# ── Payment ───────────────────────────────────────────────────────────────────
# Switch by changing PAYMENT_PROVIDER.
# Options: "stripe" | "paypal" | "disabled"
PAYMENT_PROVIDER=disabled
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PAYPAL_CLIENT_ID=...
# PAYPAL_CLIENT_SECRET=...

# ── Event Bus ─────────────────────────────────────────────────────────────────
# Switch by changing EVENT_BUS_PROVIDER.
# Options: "inprocess" | "redis"
EVENT_BUS_PROVIDER=inprocess
# REDIS_URL=redis://localhost:6379

# ── Client ────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── OAuth (optional) ──────────────────────────────────────────────────────────
GOOGLE_OAUTH_ENABLED=false
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
