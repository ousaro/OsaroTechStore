# ─────────────────────────────────────────────────────────────────────────────
# osaroTechStore Backend — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=5000

# ── Auth ──────────────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-random-secret-in-production
TOKEN_SECRET=your-very-long-random-secret-here
TOKEN_EXPIRES_IN=15m

# ── Logger ───────────────────────────────────────────────────────────────────
# Options: pino (default) | console | json
LOGGER_PROVIDER=pino

NO_COLOR=false
LOGGER_TIMESTAMP_FORMAT=YYYY-MM-DD HH:mm:ss.SSS
LOGGER_TIMESTAMP_ENABLED=true

# ── Database ──────────────────────────────────────────────────────────────────
# Options: "mongo" | "postgres"
DATABASE_PROVIDER=mongo
MONGO_URI=mongodb://localhost:27017/osarotechstore
MONGO_MIN_POOL_SIZE=2
MONGO_MAX_POOL_SIZE=10
# POSTGRES_URL=postgresql://user:pass@localhost:5432/osarotechstore

# ── Payment ───────────────────────────────────────────────────────────────────
# Options: "stripe" | "paypal" | "disabled"
PAYMENT_PROVIDER=disabled
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...


# ── Event Bus ─────────────────────────────────────────────────────────────────
# Options: "inprocess" | "redis"
EVENT_BUS_PROVIDER=inprocess
# REDIS_URL=redis://localhost:6379

# ── Product Images ────────────────────────────────────────────────────────────
# PRODUCT_IMAGE_UPLOAD_URL=https://object-storage.internal/products/
# PRODUCT_IMAGE_PUBLIC_URL=https://cdn.example.com/products/
# PRODUCT_IMAGE_UPLOAD_TOKEN=optional-storage-upload-token

# ── Admin Seed (optional, bootstraps first admin on startup) ───────────────────
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-this-password

# ── Client ────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── OAuth (optional) ──────────────────────────────────────────────────────────
GOOGLE_OAUTH_ENABLED=false
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
