// This configuration for JavaScript projects is used by editors like Visual Studio Code to provide features such as IntelliSense, code navigation, and error checking. It specifies the compiler options for JavaScript files and the directories to include in the project.
{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": ["src"]
}